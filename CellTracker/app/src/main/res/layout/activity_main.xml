<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- ── HEADER ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvStatusDot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◉"
                    android:textSize="14sp"
                    android:textColor="@color/unknown_gray"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvScanStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="READY"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12" />

                <ImageView
                    android:id="@+id/ivRadar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_radar"
                    android:visibility="invisible"
                    android:tint="@color/scan_green" />
            </LinearLayout>

            <!-- ── PRIMARY SIGNAL CARD ───────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Type + Operator row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvNetworkTypePrimary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="10sp"
                            android:textColor="@color/lte_blue"
                            android:fontFamily="monospace"
                            android:background="@drawable/badge_bg"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvOperatorPrimary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="Waiting for scan…"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="monospace"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tvSignalQuality"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="9sp"
                            android:textColor="@color/signal_good"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.08" />
                    </LinearLayout>

                    <!-- Big dBm display -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/tvSignalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="52sp"
                            android:textStyle="bold"
                            android:textColor="@color/signal_good"
                            android:fontFamily="monospace"
                            android:includeFontPadding="false" />

                        <TextView
                            android:id="@+id/tvSignalUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_marginBottom="4dp"
                            android:layout_gravity="bottom"
                            android:text="dBm"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- Signal progress bar -->
                    <ProgressBar
                        android:id="@+id/pbPrimarySignal"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/signal_progress"
                        android:layout_marginBottom="12dp" />

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:id="@+id/tvTowerCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="monospace"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvTowerLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOWERS"
                                android:textSize="9sp"
                                android:textColor="@color/text_secondary"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.1" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp"
                            android:background="@color/divider" android:layout_marginVertical="4dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:id="@+id/tvScanCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SCAN #0"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="monospace" />
                            <TextView
                                android:id="@+id/tvScanTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—ms"
                                android:textSize="9sp"
                                android:textColor="@color/text_secondary"
                                android:fontFamily="monospace" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="36dp"
                            android:background="@color/divider" android:layout_marginVertical="4dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:id="@+id/tvLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GPS —"
                                android:textSize="10sp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="monospace"
                                android:maxLines="1"
                                android:ellipsize="end" />
                            <TextView
                                android:id="@+id/tvLocationAccuracy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="9sp"
                                android:textColor="@color/text_secondary"
                                android:fontFamily="monospace" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ACTION BUTTONS ────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="12dp"
                android:weightSum="3">

                <Button
                    android:id="@+id/btnScan"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="2"
                    android:layout_marginEnd="6dp"
                    android:text="▶ SCAN"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:backgroundTint="@color/scan_green" />

                <Button
                    android:id="@+id/btnBackground"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="BG OFF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="@color/card_bg"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- ── LAST SCAN LABEL ───────────────────── -->
            <TextView
                android:id="@+id/tvLastScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="6dp"
                android:text="TOWERS"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:letterSpacing="0.14" />

            <!-- ── TOWER LIST ─────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTowers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
